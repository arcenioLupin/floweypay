# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://floweypay:<password>@localhost:5433/floweypay?schema=public"

# ─── BTC network (REQUIRED — no default) ─────────────────────────────────────
# SIGNET | MAINNET | TESTNET | REGTEST
BTC_NETWORK="SIGNET"
# Uncomment to allow mainnet — requires explicit acknowledgement
# FLOWEYPAY_MAINNET_CONFIRMED="true"

# ─── BTC RPC credentials (REQUIRED) ──────────────────────────────────────────
BTC_RPC_USER="<rpc-user>"
BTC_RPC_PASSWORD="<rpc-password>"

# ─── BTC RPC URL (optional — defaults are per BTC_NETWORK) ───────────────────
# SIGNET default:  http://127.0.0.1:38332
# MAINNET default: http://127.0.0.1:8332
BTC_RPC_URL="http://127.0.0.1:38332"

# ─── ZMQ endpoints (optional — defaults are per BTC_NETWORK) ─────────────────
# SIGNET defaults: rawtx=tcp://127.0.0.1:28334  rawblock=tcp://127.0.0.1:28335
BTC_ZMQ_RAWTX="tcp://127.0.0.1:28334"
BTC_ZMQ_RAWBLOCK="tcp://127.0.0.1:28335"

# ─── Worker observability ─────────────────────────────────────────────────────
# Path where the worker writes its heartbeat/status JSON every 30 s.
# Read by apps/web /api/worker/status and scripts/ops/check-health.ps1
# WORKER_STATUS_FILE="B:\BTC_NODE\run\worker-status.json"
