# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://floweypay:<password>@localhost:5433/floweypay?schema=public"

# ─── Node environment ────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_OTP_SECRET="<replace-with-secure-random-secret>"
# "console" → OTP printed to stdout (dev only, NOT allowed in production). "live" → sends email via Zoho.
AUTH_EMAIL_MODE="live"

# ─── Session ─────────────────────────────────────────────────────────────────
FLOWEYPAY_SESSION_COOKIE="fp_session"

# ─── BTC — network and behavior ──────────────────────────────────────────────
# SIGNET | MAINNET | TESTNET | REGTEST
BTC_NETWORK="SIGNET"
# Set to "true" only when running against real mainnet (safety guard)
# FLOWEYPAY_MAINNET_CONFIRMED="true"

BTC_ALLOW_MOCKS="true"
# mock | coingecko
BTC_RATE_PROVIDER="mock"
# mock | rpc
BTC_ADDRESS_SOURCE="mock"
# Minimum on-chain confirmations before marking a payment CONFIRMED
BTC_REQUIRED_CONFIRMATIONS="1"

# ─── BTC — business rules (safe defaults) ────────────────────────────────────
BTC_RATE_LOCK_MINUTES="15"
BTC_SUPPORTED_FIAT_CURRENCIES="USD,PEN"
BTC_MAX_AMOUNT_CENTS="10000000"
BTC_MAX_SATS="5000000000"
BTC_RATE_CACHE_TTL_MS="30000"

# ─── BTC RPC (required when BTC_ADDRESS_SOURCE=rpc) ─────────────────────────
BTC_RPC_URL="http://127.0.0.1:38332"
BTC_RPC_USER="<rpc-user>"
BTC_RPC_PASSWORD="<rpc-password>"
BTC_RPC_WALLET="floweypay-signet"

# ─── Worker status (internal observability) ───────────────────────────────────
# Path to the heartbeat file written by apps/worker every 30 s.
# Must match WORKER_STATUS_FILE in the worker's environment.
# WORKER_STATUS_FILE="B:\BTC_NODE\run\worker-status.json"

# ─── SMTP / Zoho (required when AUTH_EMAIL_MODE=live) ────────────────────────
ZOHO_SMTP_HOST="smtp.zoho.com"
ZOHO_SMTP_PORT="587"
ZOHO_SMTP_SECURE="false"
ZOHO_SMTP_USER="<email@yourdomain.com>"
ZOHO_SMTP_PASS="<zoho-app-password>"
ZOHO_FROM_NAME="FloweyPay"
ZOHO_FROM_EMAIL="<email@yourdomain.com>"
