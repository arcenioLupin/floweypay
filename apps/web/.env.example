# Core
DATABASE_URL="postgresql://floweypay:floweypay@localhost:5433/floweypay?schema=public"

# Auth
AUTH_EMAIL_MODE="console"
AUTH_OTP_SECRET="replace-me"
FLOWEYPAY_SESSION_COOKIE="fp_session"

# BTC network and lock
BTC_NETWORK="SIGNET"
BTC_RATE_LOCK_MINUTES="15"

# BTC hardening defaults
BTC_SUPPORTED_FIAT_CURRENCIES="USD,PEN"
BTC_MAX_AMOUNT_CENTS="10000000"
BTC_MAX_SATS="5000000000"
BTC_RATE_CACHE_TTL_MS="30000"

# BTC providers/sources
BTC_ALLOW_MOCKS="true"
BTC_RATE_PROVIDER="mock"
BTC_ADDRESS_SOURCE="mock"

# When BTC_ADDRESS_SOURCE=rpc
BTC_RPC_URL="http://127.0.0.1:8332"
BTC_RPC_USER="floweypay"
BTC_RPC_PASSWORD="replace-me"
